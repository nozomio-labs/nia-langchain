{
  "name": "@nozomioai/langchain-nia",
  "version": "0.1.0",
  "description": "Nia search and index API integration for LangChain.js",
  "author": "Nozomio Labs",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:nozomio-labs/nia-langchain.git"
  },
  "homepage": "https://github.com/nozomio-labs/nia-langchain/tree/main/libs/langchain-nia-js/",
  "scripts": {
    "build": "tsup",
    "lint": "eslint --cache src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --mode int",
    "format": "prettier --write \"src\"",
    "format:check": "prettier --check \"src\""
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0 <2.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.3.1",
    "prettier": "^3.5.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.3",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ]
}
